  <transform>
    <name>src_msu_psitemreceber_historico</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>oracle-consinco</connection>
    <execute_each_row>N</execute_each_row>
    <limit>0</limit>
    <sql>SELECT
    A.NROPEDIDOSUPRIM,
    A.NROEMPRESA,
    A.CENTRALLOJA,
    A.SEQPRODUTO,
    A.SEQITEM,
    A.QTDSOLICITADA,
    A.QTDSOLICITADAORIGINAL,
    A.QTDEMBALAGEM,
    A.QTDAPROVADA,
    A.QTDTOTRECEBIDA,
    A.QTDTOTCANCELADA,
    A.QTDTOTTRANSITO,
    A.STATUSITEM,
    A.DTAAPROVACAO,
    A.DTARECEBTOITEM,
    A.VLRUNITARIO,
    A.VLREMBITEM,
    A.VLREMBIPI,
    A.VLREMBICMSST,
    A.VLREMBVERBACOMPRA,
    A.ESTOQUE,
    A.OBSERVACAOITEM,
    A.MOTIVOPENDENCIA,
    A.DTAALTERACAO,
    A.USUALTERACAO
FROM CONSINCO.MSU_PSITEMRECEBER A
INNER JOIN CONSINCO.MSU_PEDIDOSUPRIM P
    ON P.NROPEDIDOSUPRIM = A.NROPEDIDOSUPRIM
    AND P.NROEMPRESA = A.NROEMPRESA
WHERE P.DTAEMISSAO BETWEEN TO_DATE('${DATA_INICIO}', 'YYYY-MM-DD') AND TO_DATE('${DATA_FIM}', 'YYYY-MM-DD')</sql>
    <variables_active>Y</variables_active>
    <attributes/>
    <GUI>
      <xloc>176</xloc>
      <yloc>96</yloc>
    </GUI>
  </transform>
