<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>maxv_abcentradabase_historico</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description/>
    <extended_description/>
    <pipeline_version/>
    <pipeline_type>Normal</pipeline_type>
    <pipeline_status>0</pipeline_status>
    <parameters>
      <parameter>
        <name>DATA_INICIO</name>
        <default_value>2024-01-01</default_value>
        <description>Data de início do lote (YYYY-MM-DD, inclusive)</description>
      </parameter>
      <parameter>
        <name>DATA_FIM</name>
        <default_value>2024-03-31</default_value>
        <description>Data de fim do lote (YYYY-MM-DD, inclusive)</description>
      </parameter>
    </parameters>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <created_user>-</created_user>
    <created_date>2026/06/12 00:00:00.000</created_date>
    <modified_user>-</modified_user>
    <modified_date>2026/06/12 00:00:00.000</modified_date>
  </info>
  <notepads>
  </notepads>
  <order>
    <hop>
      <from>src_maxv_abcentradabase</from>
      <to>sys_loaded_at</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>sys_loaded_at</from>
      <to>raw_maxv_abcentradabase</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <transform>
    <name>raw_maxv_abcentradabase</name>
    <type>TableOutput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <commit>50000</commit>
    <connection>postgresql-server</connection>
    <fields>
</fields>
    <ignore_errors>N</ignore_errors>
    <only_when_have_rows>N</only_when_have_rows>
    <partitioning_daily>N</partitioning_daily>
    <partitioning_enabled>N</partitioning_enabled>
    <partitioning_monthly>Y</partitioning_monthly>
    <return_keys>N</return_keys>
    <schema>bronze</schema>
    <specify_fields>N</specify_fields>
    <table>maxv_abcentradabase</table>
    <tablename_in_field>N</tablename_in_field>
    <tablename_in_table>Y</tablename_in_table>
    <truncate>Y</truncate>
    <use_batch>Y</use_batch>
    <attributes/>
    <GUI>
      <xloc>512</xloc>
      <yloc>96</yloc>
    </GUI>
  </transform>
  <transform>
    <name>src_maxv_abcentradabase</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>oracle-consinco</connection>
    <execute_each_row>N</execute_each_row>
    <limit>0</limit>
    <sql>SELECT
    E.NROEMPRESA,
    E2.DTAENTRADA,
    E2.DTAEMISSAO,
    A.SEQPRODUTO,
    E2.NRODOCTO,
    E2.SEQPESSOA AS SEQFORNECEDOR,
    E2.NROEMPRESA || E2.NRODOCTO || E2.SEQPESSOA AS NRODOCUMENTO,
    E2.CODGERALOPER,
    E2.OPERADOR,
    K.QTDEMBALAGEM,
    SUM((E2.QTDITEM - E2.DQTDITEM)) AS QUANTIDADE,
    SUM(E2.VLRITEM + E2.VLRIPI + E2.VLRICMSDI + E2.VLRDESPTRIBUTITEM + E2.VLRDESPNTRIBUTITEM + E2.VLRDESPFORANF + E2.VLRICMSST + E2.VLRFCPST - E2.VLRDESCITEM)
    - SUM(E2.DVLRITEM + E2.DVLRIPI + E2.DVLRICMSDI + E2.DVLRDESPTRIBUTITEM + E2.DVLRDESPNTRIBUTITEM + E2.DVLRDESPFORANF + E2.DVLRICMSST + E2.DVLRFCPST - E2.DVLRDESCITEM)
    AS VLRENTRADA,
    (SUM(E2.VLRITEM + E2.VLRIPI + E2.VLRICMSDI + E2.VLRDESPTRIBUTITEM + E2.VLRDESPNTRIBUTITEM + E2.VLRDESPFORANF + DECODE(E2.LANCAMENTOST, 'S', 0, (E2.VLRICMSST + E2.VLRFCPST))
    - E2.VLRDESCITEM - E2.VLRDESCFINANCEIRO - E2.VLRDESCTRANSF - E2.VLRDESCSUFRAMA
    - CASE WHEN 'N' = 'S' OR 'N' = 'B' THEN E2.VLRVERBAITEM ELSE 0 END)
    - SUM(E2.DVLRITEM + E2.DVLRIPI + E2.DVLRICMSDI + E2.DVLRDESPTRIBUTITEM + E2.DVLRDESPNTRIBUTITEM + E2.DVLRDESPFORANF
    + DECODE(E2.LANCAMENTOST, 'S', 0, (E2.DVLRICMSST + E2.DVLRFCPST))
    - E2.DVLRDESCITEM - E2.DVLRDESCFINANCEIRO - E2.DVLRDESCTRANSF - E2.DVLRDESCSUFRAMA
    - CASE WHEN 'N' = 'S' OR 'N' = 'B' THEN E2.DVLRVERBAITEM ELSE 0 END))
    * CASE
        WHEN (MAX(A.SEQPRODUTOBASE) IS NOT NULL AND MAX(DV.UTILACRESCCUSTPRODRELAC) = 'S')
        THEN NVL(MAX(A.PERCACRESCCUSTORELACVIG), 1)
        ELSE 1
    END
    AS VLRCUSTOBRUTO,
    SUM(
    E2.VLRITEM + E2.VLRIPI + E2.VLRICMSDI - E2.VLRIMPOSTOPRESUMCUSTO + E2.VLRDESPTRIBUTITEM + E2.VLRDESPNTRIBUTITEM + E2.VLRDESPFORANF
    - E2.VLRDESCITEM - E2.VLRDESCFINANCEIRO - E2.VLRDESCTRANSF - E2.VLRDESCSUFRAMA
    + DECODE(E2.LANCAMENTOST, 'S', 0, (E2.VLRICMSST + E2.VLRFCPST))
    - DECODE(
        E2.VLRICMSST,
        0,
        DECODE(
            E2.LANCAMENTOST,
            'C', 0,
            'S', 0,
            DECODE(
                SIGN(E2.VLRICMSCALC),
                -1, E2.VLRICMSCALC + E2.VLRICMSPRESUMIDO,
                1, E2.VLRICMSCALC + DECODE(E2.TIPOCALCICMSFISCI, 23, 0, 24, 0, 27, 0, E2.VLRICMSANTECIPADO) + E2.VLRICMSPRESUMIDO,
                0, E2.VLRICMSCALC + DECODE(E2.TIPOCALCICMSFISCI, 23, 0, 24, 0, 27, 0, E2.VLRICMSANTECIPADO) + E2.VLRICMSPRESUMIDO,
                NULL, E2.VLRICMS + CASE WHEN E2.INDSOMAFCPICMSCUSTO = 'S' AND E2.VLRICMS > 0 AND E2.VLRICMSST = 0 THEN NVL(E2.VLRFCPICMS, 0) ELSE 0 END
                + DECODE(E2.TIPOCALCICMSFISCI, 23, 0, 24, 0, 27, 0, E2.VLRICMSANTECIPADO) + E2.VLRICMSPRESUMIDO
            )
        ),
        0
    )
    - E2.VLRPIS - E2.VLRCOFINS - E2.VLRCREDIPI
    - CASE WHEN 'N' = 'S' OR 'N' = 'L' THEN E2.VLRVERBAITEM ELSE 0 END
    )
    - SUM(
    E2.DVLRITEM + E2.DVLRIPI + E2.VLRICMSDI - E2.DVLRIMPOSTOPRESUMCUSTO + E2.DVLRDESPTRIBUTITEM + E2.DVLRDESPNTRIBUTITEM + E2.DVLRDESPFORANF
    - E2.DVLRDESCITEM - E2.DVLRDESCFINANCEIRO - E2.DVLRDESCTRANSF - E2.DVLRDESCSUFRAMA
    + DECODE(E2.LANCAMENTOST, 'S', 0, (E2.DVLRICMSST + E2.VLRFCPST))
    - DECODE(
        E2.DVLRICMSST,
        0,
        DECODE(
            E2.LANCAMENTOST,
            'C', 0,
            'S', 0,
            DECODE(
                SIGN(E2.DVLRICMSCALC),
                -1, E2.DVLRICMSCALC + E2.DVLRICMSPRESUMIDO,
                1, E2.DVLRICMSCALC + DECODE(E2.TIPOCALCICMSFISCI, 23, 0, 24, 0, 27, 0, E2.DVLRICMSANTECIPADO) + E2.DVLRICMSPRESUMIDO,
                0, E2.DVLRICMSCALC + DECODE(E2.TIPOCALCICMSFISCI, 23, 0, 24, 0, 27, 0, E2.DVLRICMSANTECIPADO) + E2.DVLRICMSPRESUMIDO,
                NULL, E2.DVLRICMS + CASE WHEN E2.INDSOMAFCPICMSCUSTO = 'S' AND E2.VLRICMS > 0 AND E2.VLRICMSST = 0 THEN NVL(E2.DVLRFCPICMS, 0) ELSE 0 END
                + DECODE(E2.TIPOCALCICMSFISCI, 23, 0, 24, 0, 27, 0, E2.DVLRICMSANTECIPADO) + E2.DVLRICMSPRESUMIDO
            )
        ),
        0
    )
    - E2.DVLRPIS - E2.DVLRCOFINS - E2.DVLRCREDIPI
    - CASE WHEN 'N' = 'S' OR 'N' = 'L' THEN E2.DVLRVERBAITEM ELSE 0 END
    )
    * CASE
        WHEN (MAX(A.SEQPRODUTOBASE) IS NOT NULL AND MAX(DV.UTILACRESCCUSTPRODRELAC) = 'S')
        THEN NVL(MAX(A.PERCACRESCCUSTORELACVIG), 1)
        ELSE 1
    END
    AS VLRCUSTOLIQUIDO,
    SUM((E2.VLRITEM - E2.DVLRITEM)) AS VLRPRODUTO,
    SUM(+(E2.VLRITEM - E2.VLRDESCITEM + E2.VLRICMSSTNF + E2.VLRIPI + E2.VLRICMSDI + E2.VLRDESPTRIBUTITEM + E2.VLRDESPNTRIBUTITEM + E2.VLRFCPST)
    - (E2.DVLRITEM - E2.DVLRDESCITEM + E2.DVLRICMSST + E2.DVLRIPI + E2.DVLRDESPTRIBUTITEM + E2.DVLRDESPNTRIBUTITEM + E2.DVLRFCPST)
    ) AS VLRTOTALNF,
    SUM(E2.VLRDESCITEM + E2.VLRDESCFINANCEIRO + E2.VLRDESCTRANSF + E2.VLRDESCSUFRAMA + E2.VLROPCONTRATODESC)
    - SUM(E2.DVLRDESCITEM + E2.DVLRDESCFINANCEIRO + E2.DVLRDESCTRANSF + E2.DVLRDESCSUFRAMA + E2.DVLROPCONTRATODESC)
    AS VLRDESCONTOS,
    SUM(
        SUBSTR(
            CASE WHEN NVL(C.CMULTCUSLIQUIDOEMP - NVL(C.CMULTDCTOFORANFEMP, 0), 0) &lt; 0
            THEN 0
            ELSE NVL(C.CMULTCUSLIQUIDOEMP - NVL(C.CMULTDCTOFORANFEMP, 0), 0)
            END,
            0, 250
        ) * (E2.QTDITEM - E2.DQTDITEM)
    ) AS CUSTOFISCALTOTALENTRADA,
    CONSINCO.FC5_DIVIDE(
        SUM((+(E2.VLRITEM - E2.VLRDESCITEM + E2.VLRICMSSTNF + E2.VLRIPI + E2.VLRICMSDI + E2.VLRDESPTRIBUTITEM + E2.VLRDESPNTRIBUTITEM + E2.VLRFCPST)
            - (E2.DVLRITEM - E2.DVLRDESCITEM + E2.DVLRICMSST + E2.DVLRIPI + E2.DVLRDESPTRIBUTITEM + E2.DVLRDESPNTRIBUTITEM + E2.DVLRFCPST)
            ) * E2.PRAZOMEDIOPAG),
        SUM(+(E2.VLRITEM - E2.VLRDESCITEM + E2.VLRICMSSTNF + E2.VLRIPI + E2.VLRICMSDI + E2.VLRDESPTRIBUTITEM + E2.VLRDESPNTRIBUTITEM + E2.VLRFCPST)
            - (E2.DVLRITEM - E2.DVLRDESCITEM + E2.DVLRICMSST + E2.DVLRIPI + E2.DVLRDESPTRIBUTITEM + E2.DVLRDESPNTRIBUTITEM + E2.DVLRFCPST)
        )
    ) AS PRAZOMEDIOPAG
FROM
    CONSINCO.MAXV_ABCENTRADABASE E2,
    CONSINCO.MAP_PRODUTO A,
    CONSINCO.MAP_FAMDIVISAO D,
    CONSINCO.MAD_FAMSEGMENTO H,
    CONSINCO.MAP_FAMEMBALAGEM K,
    CONSINCO.MAX_EMPRESA E,
    CONSINCO.MAX_DIVISAO DV,
    CONSINCO.MRL_PRODUTOEMPRESA C
WHERE
    D.SEQFAMILIA = A.SEQFAMILIA
    AND E2.SEQPRODUTO = A.SEQPRODUTO
    AND E2.NRODIVISAO = D.NRODIVISAO
    AND E2.NROSEGMENTOPRINC = H.NROSEGMENTO
    AND D.SEQFAMILIA = H.SEQFAMILIA
    AND K.SEQFAMILIA = A.SEQFAMILIA
    AND DV.NRODIVISAO = E2.NRODIVISAO
    AND K.QTDEMBALAGEM = CONSINCO.FPADRAOEMBVENDA2(D.SEQFAMILIA, '1,2')
    AND C.SEQPRODUTO = E2.SEQPRODUTO
    AND C.NROEMPRESA = E2.NROEMPRESA
    AND E2.NROEMPRESA = E.NROEMPRESA
    AND E2.DTAENTRADA BETWEEN TO_DATE('${DATA_INICIO}', 'YYYY-MM-DD') AND TO_DATE('${DATA_FIM}', 'YYYY-MM-DD')
GROUP BY
    E.NROEMPRESA,
    E2.DTAENTRADA,
    E2.DTAEMISSAO,
    A.SEQPRODUTO,
    E2.NRODOCTO,
    E2.SEQPESSOA,
    E2.NROEMPRESA || E2.NRODOCTO || E2.SEQPESSOA,
    E2.CODGERALOPER,
    E2.OPERADOR,
    K.QTDEMBALAGEM</sql>
    <variables_active>Y</variables_active>
    <attributes/>
    <GUI>
      <xloc>176</xloc>
      <yloc>96</yloc>
    </GUI>
  </transform>
  <transform>
    <name>sys_loaded_at</name>
    <type>SystemInfo</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <fields>
      <field>
        <name>_loaded_at</name>
        <type>system date (fixed)</type>
      </field>
    </fields>
    <attributes/>
    <GUI>
      <xloc>320</xloc>
      <yloc>96</yloc>
    </GUI>
  </transform>
  <transform_error_handling>
  </transform_error_handling>
  <attributes/>
</pipeline>
