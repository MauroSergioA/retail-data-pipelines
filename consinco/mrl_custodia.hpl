    <execute_each_row>N</execute_each_row>
    <limit>0</limit>
    <sql>SELECT
    SEQPRODUTO,
    DTAENTRADASAIDA,
    NROEMPRESA,
    QTDESTQINICIAL,
    QTDENTRADA,
    QTDSAIDA,
    QTDCOMPRA,
    VLRTOTALCOMPRA,
    QTDVDA,
