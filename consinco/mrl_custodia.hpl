    VLRCUSBRUTOVDA,
    QTDDEVOL,
    VLRTOTALDEVOL,
    VLRCUSLIQUIDODEVOL,
    CMDIAVLRNF,
    CMDIACUSLIQUIDOEMP
FROM CONSINCO.MRL_CUSTODIA
WHERE DTAENTRADASAIDA >= TRUNC(SYSDATE) - ${WINDOW_DAYS}</sql>
