        "FORCE_IDENTIFIERS_TO_UPPERCASE": "N",
        "PREFERRED_SCHEMA_NAME": "",
        "EXTRA_OPTION_ORACLE.oracle.jdbc.ReadTimeout": "7200000",
        "EXTRA_OPTION_ORACLE.defaultRowPrefetch": "1000"
