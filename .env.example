# =============================================================================
# retail-data-pipelines — variáveis de ambiente
# Copie para .env e preencha os valores reais.
# NUNCA commite o .env — está no .gitignore.
# No Dokploy: configure estas variáveis diretamente no painel (Environment).
# =============================================================================

# PostgreSQL — destino das cargas (schema bronze)
PG_HOSTNAME=<host-servidor-producao>
PG_PORT=<porta-postgresql>
PG_DATABASE=<nome-do-database>
PG_USERNAME=<usuario-postgresql>
PG_PASSWORD=<senha-postgresql>
PG_URL=jdbc:postgresql://<host-servidor-producao>:<porta-postgresql>/<nome-do-database>

# Oracle ERP (Consinco) — fonte dos dados
CONSINCO_HOSTNAME=<host-oracle-erp>
CONSINCO_PORT=<porta-oracle>
CONSINCO_DATABASE=<service-name-oracle>
CONSINCO_USERNAME=<usuario-oracle>
CONSINCO_PASSWORD=<senha-oracle>
CONSINCO_URL=jdbc:oracle:thin:@//<host-oracle-erp>:<porta-oracle>/<service-name-oracle>

# Hop Server
HOP_SERVER_USER=<usuario-do-hop-server>
HOP_SERVER_PASS=<senha-do-hop-server>
TZ=America/Sao_Paulo
HOP_OPTIONS=-Xmx3g

# dbt container
DBT_USERNAME=<usuario-dbt-postgresql>
DBT_PASSWORD=<senha-dbt-postgresql>

# n8n (compose/n8n.yml)
N8N_HOST=<dominio-editor-n8n>
N8N_WEBHOOK_HOST=<dominio-webhook-n8n>
N8N_DB_PASSWORD=<senha-n8n-user-postgresql>
ENCRYPTION_KEY=<chave-aleatoria-32-bytes-hex>
JWT_SECRET=<chave-aleatoria-32-bytes-hex>
N8N_RUNNERS_SECRET=<string-secreta-para-runners>
