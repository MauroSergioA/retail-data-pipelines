FROM python:3.12-slim

RUN useradd -m -s /bin/bash dbt_user

WORKDIR /dbt

COPY transform/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY transform/ .

COPY scripts/init-dbt.sh /usr/local/bin/init-dbt.sh
COPY scripts/dbt-server.py /usr/local/bin/dbt-server.py
RUN chmod +x /usr/local/bin/init-dbt.sh

USER dbt_user

EXPOSE 8000

ENTRYPOINT ["/usr/local/bin/init-dbt.sh"]
CMD ["python3", "/usr/local/bin/dbt-server.py"]
